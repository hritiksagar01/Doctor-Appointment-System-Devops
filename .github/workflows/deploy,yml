name: Deploy .NET App

on:
  push:
    branches:
      - main

jobs:
  deploy:
    runs-on: ubuntu-latest

    steps:
      # 1️⃣ Checkout code
      - name: Checkout code
        uses: actions/checkout@v3

      # 2️⃣ Debug (IMPORTANT - helps you see folder structure)
      - name: Debug folder structure
        run: ls -R

      # 3️⃣ Setup .NET
      - name: Setup .NET
        uses: actions/setup-dotnet@v3
        with:
          dotnet-version: '8.0.x'

      # 4️⃣ Build & Publish (NO FOLDER ISSUE NOW)
      - name: Build & Publish
        run: |
          dotnet restore "Doctor Appointment System.sln"
          dotnet build "Doctor Appointment System.sln" -c Release
          dotnet publish "Doctor Appointment System.sln" -c Release -o publish

      # 5️⃣ Deploy to Server
      - name: Deploy to Server
        uses: appleboy/ssh-action@v1.0.0
        with:
          host: ${{ secrets.SERVER_IP }}
          username: ${{ secrets.SERVER_USER }}
          key: ${{ secrets.SERVER_SSH_KEY }}
          script: |
            cd /var/www/app

            # Pull latest code
            git pull origin main

            # Build on server (safe)
            dotnet publish "Doctor Appointment System.sln" -c Release -o /var/www/app/out

            # Restart service
            sudo systemctl restart myapp